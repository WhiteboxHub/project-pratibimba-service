# -------------------------------------------------------------------
# Prathibimba Root Docker Configuration
# -------------------------------------------------------------------

# 1. Provide the domain name you purchased / configured in GoDaddy.
# Caddy will automatically ping Let's Encrypt using this URL to generate 
# a 100% free, legally secure Auto-Renewing SSL Certificate securely in memory.
DOMAIN_NAME=screenshots.your-website.com

# 2. Add your company's existing database credentials 
# This injects straight into the server container to enable Unified Auth!
DB_HOST=10.0.0.X
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name
DB_PORT=3306
