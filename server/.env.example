# Server port (default: 3000)
PORT=3000

# Bind host (default: 127.0.0.1)
HOST=127.0.0.1

# API key for WebSocket authentication (must match the extension's key)
X_API_KEY=my-super-secret-key

# SQLite database file path (default: buffer.db)
DB_PATH=buffer.db

# Directory for file-based storage (default: storage)
STORAGE_DIR=storage

# Interval in ms for flushing the DB buffer to disk (default: 10000)
FLUSH_INTERVAL_MS=10000

# Interval in ms for screenshot capture commands sent to extensions (default: 10000)
SCREENSHOT_INTERVAL_MS=10000

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info
