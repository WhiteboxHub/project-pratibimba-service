# Server configuration
PORT=3000
HOST=127.0.0.1

# SQLite database file path for internal sync tracking
DB_PATH=buffer.db

# Directory for file-based storage where screenshots are saved
STORAGE_DIR=storage

# Interval in ms for flushing the SQLite DB buffer to disk
FLUSH_INTERVAL_MS=10000

# Interval in ms for screenshot capture commands sent to extensions
SCREENSHOT_INTERVAL_MS=10000

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# -------------------------------------------------------------------
# MySQL Database Configuration (Required for unified auth flow)
# -------------------------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=app_user
DB_PORT=3306

# Note: X_API_KEY is obsolete since Extension Auth now issues its own
# dynamic session tokens per device stored in the MySQL extension_keys table.
