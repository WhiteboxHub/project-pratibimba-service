# Server configuration
PORT=3000
HOST=127.0.0.1

# SQLite database file path for internal sync tracking
DB_PATH=buffer.db

# Directory for file-based storage where screenshots are saved
STORAGE_DIR=storage

# Interval in ms for flushing the SQLite DB buffer to disk
FLUSH_INTERVAL_MS=10000

# Interval in ms for screenshot capture commands sent to extensions
SCREENSHOT_INTERVAL_MS=10000

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# -------------------------------------------------------------------
# Unified Authentication (Company MySQL Infrastructure)
# -------------------------------------------------------------------
# These credentials map perfectly to your company's existing authuser
# and employee tables. This creates the bidirectional security wall 
# for Admins (Dashboard) vs Employees (Chrome Extension).
DB_HOST=10.0.0.X                  # e.g., your existing private network DB IP
DB_USER=root                      # e.g., db_admin
DB_PASSWORD=your_secure_password  # e.g., *********
DB_NAME=your_database_name        # e.g., company_central_db
DB_PORT=3306                      # Default MySQL port
